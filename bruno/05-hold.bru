meta {
  name: Hold booking
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/bookings/hold
  body: json
  auth: none
}

headers {
  X-User-Id: {{userId}}
}

body:json {
  {
    "sessionId": "{{sessionId}}",
    "seatIds": ["{{seatId}}"]
  }
}

vars:post-response {
  bookingId: res.body.id
}
