  "info": {
    "title": "Cinemafia API",
    "description": "Cinemafia — Layered (N-tier). Canonical REST contract for the series.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Emulated auth token."
      },
      "X-User-Id": {
        "type": "apiKey",
        "in": "header",
        "name": "X-User-Id"
      }
    },
    "schemas": {
      "HallRefDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "MovieRefDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title"
        ]
      },
      "SessionMovieSummaryDto": {
        "type": "object",
        "properties": {
          "position": {
            "type": "number",
            "description": "Order of the movie within the session bundle."
          },
          "movie": {
            "$ref": "#/components/schemas/MovieRefDto"
          }
        },
        "required": [
          "position",
          "movie"
        ]
      },
      "SessionSummaryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "GENRE_BLOCK",
              "COMBO",
              "MARATHON",
              "SPECIAL_CUT",
              "SPECIAL_EVENT",
              "PREMIERE"
            ]
          },
          "startsAt": {
            "type": "string",
            "format": "date-time"
          },
          "endsAt": {
            "type": "string",
            "format": "date-time"
          },
          "earlyAccessUntil": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "minLoyaltyDegree": {
            "type": "number",
            "description": "Minimum loyalty degree required to access the session."
          },
          "basePriceStandardCents": {
            "type": "number"
          },
          "basePriceReclinerCents": {
            "type": "number"
          },
          "basePricePremiumCents": {
            "type": "number"
          },
          "cabinPriceCents": {
            "type": "number"
          },
          "hall": {
            "$ref": "#/components/schemas/HallRefDto"
          },
          "movies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionMovieSummaryDto"
            }
          }
        },
        "required": [
          "id",
          "kind",
          "startsAt",
          "endsAt",
          "earlyAccessUntil",
          "minLoyaltyDegree",
          "basePriceStandardCents",
          "basePriceReclinerCents",
          "basePricePremiumCents",
          "cabinPriceCents",
          "hall",
          "movies"
        ]
      },
      "SeatDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "rowLabel": {
            "type": "string"
          },
          "number": {
            "type": "number"
          },
          "tier": {
            "type": "string",
            "enum": [
              "STANDARD",
              "RECLINER",
              "PREMIUM"
            ]
          }
        },
        "required": [
          "id",
          "rowLabel",
          "number",
          "tier"
        ]
      },
      "CabinDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "capacity": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "name",
          "capacity"
        ]
      },
      "HallDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "seats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeatDto"
            }
          },
          "cabins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CabinDto"
            }
          }
        },
        "required": [
          "id",
          "name",
          "seats",
          "cabins"
        ]
      },
      "MovieDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "durationMin": {
            "type": "number"
          },
          "releaseYear": {
            "type": "number",
            "nullable": true
          },
          "synopsis": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "title",
          "durationMin",
          "releaseYear",
          "synopsis"
        ]
      },
      "SessionMovieDto": {
        "type": "object",
        "properties": {
          "position": {
            "type": "number"
          },
          "movie": {
            "$ref": "#/components/schemas/MovieDto"
          }
        },
        "required": [
          "position",
          "movie"
        ]
      },
      "SessionDetailResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "GENRE_BLOCK",
              "COMBO",
              "MARATHON",
              "SPECIAL_CUT",
              "SPECIAL_EVENT",
              "PREMIERE"
            ]
          },
          "startsAt": {
            "type": "string",
            "format": "date-time"
          },
          "endsAt": {
            "type": "string",
            "format": "date-time"
          },
          "earlyAccessUntil": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "minLoyaltyDegree": {
            "type": "number"
          },
          "basePriceStandardCents": {
            "type": "number"
          },
          "basePriceReclinerCents": {
            "type": "number"
          },
          "basePricePremiumCents": {
            "type": "number"
          },
          "cabinPriceCents": {
            "type": "number"
          },
          "hall": {
            "$ref": "#/components/schemas/HallDto"
          },
          "movies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionMovieDto"
            }
          },
          "takenSeatIds": {
            "description": "Seat ids currently held or confirmed.",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "kind",
          "startsAt",
          "endsAt",
          "earlyAccessUntil",
          "minLoyaltyDegree",
          "basePriceStandardCents",
          "basePriceReclinerCents",
          "basePricePremiumCents",
          "cabinPriceCents",
          "hall",
          "movies",
          "takenSeatIds"
        ]
      },
      "MembershipDto": {
        "type": "object",
        "properties": {
          "tier": {
            "type": "string",
            "enum": [
              "BASIC",
              "PLUS",
              "PRO"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "EXPIRED"
            ]
          },
          "validUntil": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "tier",
          "status",
          "validUntil"
        ]
      },
      "EntitlementsDto": {
        "type": "object",
        "properties": {
          "effectiveGuestQuota": {
            "type": "number",
            "description": "base(tier) + loyalty bonus."
          },
          "discountPercent": {
            "type": "number"
          },
          "canEarlyAccess": {
            "type": "boolean"
          }
        },
        "required": [
          "effectiveGuestQuota",
          "discountPercent",
          "canEarlyAccess"
        ]
      },
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "loyaltyDegree": {
            "type": "number"
          },
          "membership": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/MembershipDto"
              }
            ]
          },
          "entitlements": {
            "$ref": "#/components/schemas/EntitlementsDto"
          }
        },
        "required": [
          "userId",
          "displayName",
          "loyaltyDegree",
          "membership",
          "entitlements"
        ]
      },
      "HoldBookingDto": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "seatIds": {
            "description": "Seat ids to hold (mutually exclusive with cabinId).",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cabinId": {
            "type": "string",
            "description": "Cabin id to hold (mutually exclusive with seatIds)."
          },
          "guestCount": {
            "type": "number",
            "description": "Guests to bring (must fit the effective guest quota).",
            "minimum": 0
          }
        },
        "required": [
          "sessionId"
        ]
      },
      "BookingSeatRefDto": {
        "type": "object",
        "properties": {
          "rowLabel": {
            "type": "string"
          },
          "number": {
            "type": "number"
          },
          "tier": {
            "type": "string",
            "enum": [
              "STANDARD",
              "RECLINER",
              "PREMIUM"
            ]
          }
        },
        "required": [
          "rowLabel",
          "number",
          "tier"
        ]
      },
      "BookingSeatDto": {
        "type": "object",
        "properties": {
          "seatId": {
            "type": "string"
          },
          "seat": {
            "$ref": "#/components/schemas/BookingSeatRefDto"
          }
        },
        "required": [
          "seatId",
          "seat"
        ]
      },
      "BookingCabinRefDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "BookingPaymentDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "SUCCEEDED",
              "FAILED",
              "REFUNDED"
            ]
          },
          "amountCents": {
            "type": "number"
          }
        },
        "required": [
          "status",
          "amountCents"
        ]
      },
      "BookingResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "HELD",
              "CONFIRMED",
              "CANCELLED",
              "EXPIRED"
            ]
          },
          "sessionId": {
            "type": "string"
          },
          "cabinId": {
            "type": "string",
            "nullable": true
          },
          "guestCount": {
            "type": "number"
          },
          "totalPriceCents": {
            "type": "number"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "confirmedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "cancelledAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "seats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BookingSeatDto"
            }
          },
          "cabin": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BookingCabinRefDto"
              }
            ]
          },
          "payment": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BookingPaymentDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "status",
          "sessionId",
          "cabinId",
          "guestCount",
          "totalPriceCents",
          "expiresAt",
          "confirmedAt",
          "cancelledAt",
          "createdAt",
          "seats",
          "cabin",
          "payment"
        ]
      },
      "BookingSummaryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "HELD",
              "CONFIRMED",
              "CANCELLED",
              "EXPIRED"
            ]
          },
          "sessionId": {
            "type": "string"
          },
          "guestCount": {
            "type": "number"
          },
          "totalPriceCents": {
            "type": "number"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "status",
          "sessionId",
          "guestCount",
          "totalPriceCents",
