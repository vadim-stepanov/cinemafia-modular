              "type": "string",
              "enum": [
                "GENRE_BLOCK",
                "COMBO",
                "MARATHON",
                "SPECIAL_CUT",
                "SPECIAL_EVENT",
                "PREMIERE"
              ]
            }
          },
          {
            "name": "from",
            "required": false,
            "in": "query",
            "description": "ISO 8601 — only sessions starting at or after this instant.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "required": false,
            "in": "query",
            "description": "ISO 8601 — only sessions starting at or before this instant.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionSummaryResponseDto"
