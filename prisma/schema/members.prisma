// Members module — owns member profiles and paid memberships.
// loyaltyDegree lives here as an accumulating rank stat (domain-spec §5); the
// loyalty module mutates it through this module's public service, not its tables.
// Bookings / club notes reference a member by id only (no relations back here).

enum MembershipTier {
  BASIC
  PLUS
  PRO

  @@map("membership_tier")
}

enum MembershipStatus {
  ACTIVE
  EXPIRED

  @@map("membership_status")
}

model Member {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  displayName   String   @map("display_name")
  loyaltyDegree Int      @default(0) @map("loyalty_degree")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  membership Membership?

  @@map("members")
}

model Membership {
  id         String           @id @default(cuid())
  memberId   String           @unique @map("member_id")
  tier       MembershipTier
  status     MembershipStatus @default(ACTIVE)
  guestQuota Int              @default(0) @map("guest_quota")
  validFrom  DateTime         @map("valid_from") @db.Timestamptz(3)
  validUntil DateTime         @map("valid_until") @db.Timestamptz(3)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("memberships")
}
