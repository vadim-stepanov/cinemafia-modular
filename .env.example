# Copy to .env for local development. Postgres runs via docker-compose on host port 5443.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://cinemafia:dev@localhost:5443/cinemafia

# Booking
HOLD_TTL_SECONDS=600
REFUND_WINDOW_HOURS=24
PARTIAL_REFUND_PERCENT=50

# Emulated payment gateway (set a non-zero failure rate / latency to exercise the boundary)
PAYMENT_FAILURE_RATE=0
PAYMENT_LATENCY_MS=0
